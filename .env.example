# Supabase - Create a project at https://supabase.com
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Google Places - Enable at https://console.cloud.google.com/apis
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=

# Ticketmaster - Sign up at https://developer.ticketmaster.com
TICKETMASTER_API_KEY=

# SeatGeek - Sign up at https://platform.seatgeek.com
SEATGEEK_CLIENT_ID=

# Anthropic - For LLM event extraction pipeline
ANTHROPIC_API_KEY=

# RevenueCat - iOS public API key (starts with appl_)
# Get from https://app.revenuecat.com → Project Settings → API keys
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
